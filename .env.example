# Database
DB_ROOT_PASSWORD="change-me"
DB_USER=linkup_user
DB_PASSWORD="change-me"

# JWT — generate with: openssl rand -hex 64 (minimum 256 bits)
JWT_SECRET=change-me

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Platform super-user (email must match an existing or new account; promoted on login/startup)
ADMIN_EMAIL=admin@example.com

# Frontend (browser and nginx)
VITE_API_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
# For `npm run dev` (Vite), set FRONTEND_URL=http://localhost:5173 so invitation links hit the dev app.

# Workspace invitation emails (Spring Boot JavaMailSender)
# For Gmail, use an App Password and set host to smtp.gmail.com, port 587.
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_FROM=noreply@yourdomain.com
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
